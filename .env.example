APP_NAME=Invexa
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=invexa
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120

# ─────────────────────────────────────────────
# E-MAIL — Resend (https://resend.com)
# ─────────────────────────────────────────────
# 1. Crie uma conta em resend.com
# 2. Adicione e verifique seu domínio
# 3. Gere uma API Key em resend.com/api-keys
# 4. Instale o driver: composer require resend/laravel
# ─────────────────────────────────────────────
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=noreply@seudominio.com.br
MAIL_FROM_NAME="Invexa"
RESEND_API_KEY=re_SUA_CHAVE_AQUI

# Fallback para desenvolvimento local (descomente para usar log)
# MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"
