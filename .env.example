APP_NAME=Invexa
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=invexa
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ── E-mail
# Desenvolvimento: MAIL_MAILER=log (não envia nada)
# Produção: MAIL_MAILER=smtp (Brevo)
MAIL_MAILER=log
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=seu_email@cadastro_brevo.com
MAIL_PASSWORD=chave_smtp_brevo
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@offerjetshop.net"
MAIL_FROM_NAME="${APP_NAME}"

# Resend (alternativa) — obter em https://resend.com/api-keys
# RESEND_API_KEY=re_...

