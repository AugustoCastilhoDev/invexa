APP_NAME=Invexa
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# Em produção, substituir pelo domínio real (ex: https://invexa.com.br)
APP_URL=https://invexa.com.br

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=invexa
# DB_USERNAME=root
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120
# Em produção com HTTPS, SEMPRE manter como true
SESSION_SECURE_COOKIE=true

# ── E-mail
# Desenvolvimento: MAIL_MAILER=log (não envia nada)
# Produção: MAIL_MAILER=smtp (Brevo)
MAIL_MAILER=log
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=seu_email@cadastro_brevo.com
MAIL_PASSWORD=chave_smtp_brevo
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@seudominio.com"
MAIL_FROM_NAME="${APP_NAME}"

# Resend (alternativa) — obter em https://resend.com/api-keys
# RESEND_API_KEY=re_...

# ── Stripe / Laravel Cashier
STRIPE_SECRET=sk_live_SUA_CHAVE_AQUI
STRIPE_KEY=pk_live_SUA_CHAVE_AQUI
STRIPE_WEBHOOK_SECRET=whsec_SUA_CHAVE_WEBHOOK_AQUI

STRIPE_PRICE_PRO_LAUNCH_MONTHLY=price_1TZZQE3wN3kkGmhWN7WeiL0v
STRIPE_PRICE_PRO_LAUNCH_ANNUAL=price_1TZj903wN3kkGmhW0kosrKyR
